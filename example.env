# Server Configuration
VOCDONI_SERVERURL=http://localhost:8080
VOCDONI_HOST=0.0.0.0
VOCDONI_PORT=8080
VOCDONI_SECRET=supersecret
VOCDONI_WEBURL=https://saas-dev.vocdoni.app

# Vocdoni API Configuration
VOCDONI_VOCDONIAPI=https://api-dev.vocdoni.net/v2
VOCDONI_PRIVATEKEY=your-vochain-private-key-here
VOCDONI_FULLTRANSPARENTMODE=false

# MongoDB Configuration
VOCDONI_MONGOURL=mongodb://localhost:27017
VOCDONI_MONGODB=vocdoni-saas

# SMTP Email Configuration
VOCDONI_SMTPSERVER=smtp.server.com
VOCDONI_SMTPPORT=587
VOCDONI_SMTPUSERNAME=admin
VOCDONI_SMTPPASSWORD=password
VOCDONI_EMAILFROMADDRESS=admin@email.com
VOCDONI_EMAILFROMNAME=Vocdoni

# Optional backup SMTP relay for email failover.
# Leave VOCDONI_BACKUPSMTPSERVER empty to disable. When set (together with the
# backup username and password), email is sent through the primary relay and
# falls over to this backup if the primary submission fails. The backup shares
# the same sender identity (VOCDONI_EMAILFROMADDRESS / VOCDONI_EMAILFROMNAME);
# only the relay below differs, so it must be authorized to send for the same
# domain (SPF/DKIM/DMARC).
# VOCDONI_BACKUPSMTPSERVER=smtp.backup-provider.com
# VOCDONI_BACKUPSMTPPORT=587
# VOCDONI_BACKUPSMTPUSERNAME=admin
# VOCDONI_BACKUPSMTPPASSWORD=password

# Twilio SMS Configuration
VOCDONI_TWILIOACCOUNTSID=your-twilio-account-sid
VOCDONI_TWILIOAUTHTOKEN=your-twilio-auth-token
VOCDONI_TWILIOFROMNUMBER=+1234567890

# Stripe Configuration
VOCDONI_STRIPEAPISECRET=sk_test_your_stripe_secret_key
VOCDONI_STRIPEWEBHOOKSECRET=whsec_your_stripe_webhook_secret
# STRIPE_ESSENTIAL_PRODUCT_ID=
# STRIPE_PREMIUM_PRODUCT_ID=
# STRIPE_FREE_PRODUCT_ID=
# STRIPE_CUSTOM_PRODUCT_ID=

# OAuth Configuration
VOCDONI_OAUTHSERVICEURL=http://oauth.vocdoni.net
